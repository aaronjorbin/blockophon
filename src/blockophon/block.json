{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockophon/blockophon",
	"version": "0.1.0",
	"title": "Blockophon",
	"category": "theme",
	"icon": "smiley",
	"description": "Colophon block",
	"example": {},
	"supports": {
		"html": false,
		"color": {
			"background": false,
			"text": true,
			"link": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"showTheme": {
			"type": "boolean",
			"default": true
		},
		"showTypography": {
			"type": "boolean",
			"default": true
		},
		"useAiText": {
			"type": "boolean",
			"default": false
		},
		"customText": {
			"type": "string",
			"default": ""
		}
	},
	"textdomain": "blockophon",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
