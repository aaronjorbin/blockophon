{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockophon/plugins",
	"version": "0.1.0",
	"title": "Blockophon Plugins",
	"category": "theme",
	"description": "Displays the active plugin count and optional plugin details.",
	"supports": {
		"html": false
	},
	"attributes": {
		"showPlugins": {
			"type": "boolean",
			"default": true
		},
		"showPluginDetails": {
			"type": "boolean",
			"default": true
		}
	},
	"textdomain": "blockophon",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
