{
	"name": "blockophon",
	"version": "0.1.0",
	"description": "Colophon block",
	"author": "Aaron Jorbin <aaron@jorb.in> (https://aaron.jorb.in)",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "WP_EXPERIMENTAL_MODULES=1 wp-scripts build --webpack-copy-php --blocks-manifest",
		"format": "wp-scripts format",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:php",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"lint:php": "composer phpcs",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "WP_EXPERIMENTAL_MODULES=1 wp-scripts start --webpack-copy-php --blocks-manifest",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/blockophon php vendor/bin/phpunit",
		"dump:option": "wp-env run cli wp option get blockophon_colophon_data"
	},
	"dependencies": {
		"@wordpress/api-fetch": "7.48.1",
		"@wordpress/block-editor": "15.21.1",
		"@wordpress/blocks": "15.21.1",
		"@wordpress/components": "35.0.1",
		"@wordpress/element": "8.0.1",
		"@wordpress/i18n": "6.21.1",
		"@wordpress/interactivity": "6.48.1",
		"@wordpress/server-side-render": "6.24.1"
	},
	"devDependencies": {
		"@wordpress/env": "11.8.1",
		"@wordpress/eslint-plugin": "25.4.1",
		"@wordpress/scripts": "32.4.1"
	}
}
